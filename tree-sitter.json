{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "direnv",
      "camelcase": "Direnv",
      "title": "Direnv",
      "scope": "source.direnv",
      "file-types": [
        ".envrc"
      ],
      "injection-regex": "^direnv$",
      "class-name": "TreeSitterDirenv"
    }
  ],
  "metadata": {
    "version": "1.0.0",
    "license": "MPL-2.0",
    "description": "Direnv grammar for tree-sitter",
    "authors": [
      {
        "name": "NotAShelf",
        "email": "raf@notashelf.dev"
      }
    ],
    "links": {
      "repository": "https://github.com/notashelf/tree-sitter-direnv"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": true
  }
}
